{
  "info": {
    "name": "Voxel API Tests",
    "description": "Coleção de testes para a API Voxel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "    pm.environment.set(\"usuarioId\", jsonData.usuario.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n    \"email\": \"admin@voxel.com\",\\n    \"senha\": \"123456\"\\n}"
            },
            "url": {
              "raw": "http://localhost:5500/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5500",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - João",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n    \"email\": \"joao@voxel.com\",\\n    \"senha\": \"123456\"\\n}"
            },
            "url": {
              "raw": "http://localhost:5500/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5500",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Registrar Novo Usuário",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n    \"nome\": \"Novo Usuário\",\\n    \"email\": \"novo@voxel.com\",\\n    \"senha\": \"senha123\"\\n}"
            },
            "url": {
              "raw": "http://localhost:5500/api/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5500",
              "path": ["api", "auth", "registrar"]
            }
          }
        },
        {
          "name": "Validar Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5500/api/auth/validar-token/{{token}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5500",
              "path": ["api", "auth", "validar-token", "{{token}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Home",
      "item": [
        {
          "name": "Teste Conexão",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5500/api/home/teste",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5500",
              "path": ["api", "home", "teste"]
            }
          }
        },
        {
